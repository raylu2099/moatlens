# ========================================
# Moatlens — single-user config
# Copy to .env and fill in your API keys.
# ========================================

# --- Required API keys (Moatlens 核心) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxx
FINANCIAL_DATASETS_API_KEY=xxxxxxxxxxxx

# --- Optional but useful (v0.6+) ---
# FRED — free, macro/10Y rate; falls back to 4.3% if absent
FRED_API_KEY=xxxxxxxxxxxx
# Alpha Vantage — free tier, market-intel sentiment
ALPHA_VANTAGE_API_KEY=xxxxxxxxxxxx
# Finnhub — free tier 60/min, analyst consensus + earnings surprise
FINNHUB_API_KEY=xxxxxxxxxxxx
# sec-api.io — 100/mo free, structured SEC filings + insider (Form 4) data
SEC_API_IO_KEY=xxxxxxxxxxxx
# MarketAux — 100/day free, entity-level news sentiment
MARKETAUX_API_KEY=xxxxxxxxxxxx

# --- Telegram (shared with market-intel) ---
TELEGRAM_BOT_TOKEN=xxxxxxxxxxxx
TELEGRAM_CHAT_ID=xxxxxxxxxxxx

# --- Claude model selection ---
CLAUDE_MODEL=claude-sonnet-4-6

# --- Perplexity models (sonar / sonar-pro only; never reasoning / deep-research) ---
PPLX_MODEL_SEARCH=sonar
PPLX_MODEL_ANALYSIS=sonar-pro
PPLX_SEARCH_CONTEXT=high

# --- Coach mode (v0.4+) ---
# haiku: warmer, +$0.04/audit cost · rule: template fallback, zero extra cost
MOATLENS_COACH=haiku

# --- Paths (optional overrides; Mac users should set MOATLENS_DATA_DIR) ---
# MOATLENS_DATA_DIR=/var/lib/moatlens/data
# MOATLENS_CACHE_DIR=/var/lib/moatlens/cache

# --- Cache TTL (seconds) ---
CACHE_FUNDAMENTALS_TTL=43200   # 12h — financial statements don't change intra-day
CACHE_PERPLEXITY_TTL=21600     # 6h — news stays warm
CACHE_MACRO_TTL=86400          # 24h — FRED updates daily

# --- market-intel only (if you share .env between both projects) ---
WATCHLIST=META:Meta,GOOGL:Google,NVDA:Nvidia,TSLA:Tesla,NVO:Novo Nordisk
HISTORY_WINDOW_DAYS=30
MARKET_TZ=US/Pacific
CLAUDE_RUNNER=cli
