# ========================================
# Moatlens configuration (BYOK model)
# Copy to .env and fill in your API keys.
# Users on the hosted version enter these via the UI.
# ========================================

# --- Required BYOK API keys ---
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Get yours at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxx

# Get yours at: https://financialdatasets.ai (paid, starts $49/mo)
FINANCIAL_DATASETS_API_KEY=xxxxxxxxxxxx

# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html (free, instant)
FRED_API_KEY=xxxxxxxxxxxx

# --- Claude model selection ---
CLAUDE_MODEL=claude-sonnet-4-5

# --- Perplexity models (sonar is cheapest; avoid deep-research) ---
PPLX_MODEL_SEARCH=sonar
PPLX_MODEL_ANALYSIS=sonar-pro

# --- Web app secrets ---
SECRET_KEY=change-me-to-a-random-32-byte-string
# Used to encrypt per-user BYOK keys at rest. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
KEY_ENCRYPTION_KEY=change-me-also

# --- Paths ---
# MOATLENS_DATA_DIR=/var/lib/moatlens/data
# MOATLENS_CACHE_DIR=/var/lib/moatlens/cache

# --- Cache TTL (seconds) ---
CACHE_FUNDAMENTALS_TTL=43200   # 12h — financial statements don't change intra-day
CACHE_PERPLEXITY_TTL=21600     # 6h — news updates
CACHE_MACRO_TTL=86400          # 24h — FRED updates daily
